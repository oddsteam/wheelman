<div class="min-h-screen bg-gray-50 py-6 ">
  <div class="max-w-xl mx-auto">

    <!-- Header -->
    <div class="mb-6">
      <%= link_to "← All Event", events_path,
        class: "inline-block px-4 py-2 border border-[#95C24A] rounded-full text-sm text-gray-700 hover:bg-green-50" %>

      <h1 class="text-2xl font-bold mt-4">Create Event</h1>
    </div>

    <%= form_with model: @event, class: "bg-gray-100 rounded-2xl shadow-sm p-5 md:p-6 space-y-5" do |form| %>
      <div class="mb-4">
        <%= form.label :photo, "Photo", class: "block mb-1 font-medium" %>

        <%= form.file_field :photo,
            accept: "image/jpeg,image/png,image/heic",
            class: "w-full text-sm file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-gray-100 file:text-gray-700" %>
        <% @event.errors.full_messages_for(:photo).each do |message| %>
          <p class="mt-1 text-sm text-red-600"><%= message %></p>
        <% end %>
      </div>  
      <div>
        <%= form.label :name, "Event Name" %><br>
        <%= form.text_field :name, placeholder: "ลองแกล้งๆตั้งชื่อมาหน่อยจ้า", class: "w-full p-3 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-[#95C24A]" %>
      </div>
      <div class="mb-4">
        <label class="block mb-2 font-medium">Activity Type</label>

        <div class="flex gap-3">

          <label class="cursor-pointer">
            <%= form.check_box :activity_type, { multiple: true, class: "hidden peer" }, "swimming", nil %>
            <div class="px-4 py-2 border border-gray-300 bg-white rounded-xl peer-checked:border-[#4AA2C2] peer-checked:ring-1 peer-checked:ring-[#4AA2C2]">
              🏊 Swimming
            </div>
          </label>
          

          <label class="cursor-pointer">
            <%= form.check_box :activity_type, { multiple: true, class: "hidden peer" }, "running", nil %>
            <div class="px-4 py-2 border border-gray-300 bg-white rounded-xl peer-checked:border-[#95C24A] peer-checked:ring-1 peer-checked:ring-[#95C24A]">
              🏃 Running
            </div>
          </label>

          <label class="cursor-pointer">
            <%= form.check_box :activity_type, { multiple: true, class: "hidden peer" }, "cycling", nil %>
            <div class="px-4 py-2 border border-gray-300 bg-white rounded-xl peer-checked:border-[#E76903] peer-checked:ring-1 peer-checked:ring-[#E76903]">
              🚴 Cycling
            </div>
          </label>
        </div>
      </div>
      <div class="mb-4">
      <label class="block mb-2 font-medium">Category</label>

      <div class="flex gap-3">

        <label class="cursor-pointer">
          <%= form.radio_button :category, "race", class: "hidden peer" %>
          <span class="px-4 py-2 border border-gray-300 rounded-lg bg-white
                      peer-checked:border-[#95C24A] peer-checked:ring-1 peer-checked:ring-[#95C24A]">
            Race
          </span>
        </label>

        <label class="cursor-pointer">
          <%= form.radio_button :category, "camp", class: "hidden peer" %>
          <span class="px-4 py-2 border border-gray-300 rounded-lg bg-white
                      peer-checked:border-[#95C24A] peer-checked:ring-1 peer-checked:ring-[#95C24A]">
            Camp
          </span>
        </label>

      </div>
    </div>
      <div>
        <%= form.label :description, "Description" %><br>
        <%= form.text_field :description, placeholder: "ทำกิจกรรมอะไรกันบ้าง, กินข้าวหรือดริ๊งๆ", class: "w-full p-3 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-[#95C24A]" %>
      </div>
      <div>
        <%= form.label :location, "Location" %><br>
        <%= form.text_field :location_description, placeholder: "ไหนลองบอกที่ๆจะไปมาหน่อยสิ๊", class: "w-full p-3 mb-2 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-[#95C24A]" %><br>
        <%= form.text_field :location_link, placeholder: "Link Google Map (Optional)", class: "w-full p-3 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-[#95C24A]" %>
      </div>

      <div class="space-y-2">
        <label class="block text-sm font-medium">Date Range</label>

        <input
          type="text"
          id="date_range"
          name="date_range"
          class="w-full p-3 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-[#95C24A]"
          placeholder="Select date range"
        >
        <%= form.hidden_field :start_date, id: "start_date" %>
        <%= form.hidden_field :end_date, id: "end_date" %>
      </div>

      <div>
        <%= form.submit "Create Event", class: "w-full py-3 rounded-xl bg-gray-300 text-gray-700 font-medium hover:bg-gray-400 transition" %>
      </div>
    <% end %>
  </div>
</div>