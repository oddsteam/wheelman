<div class="min-h-screen bg-gray-50 py-2 ">
  <div class="max-w-xl mx-auto">

    <!-- Header -->
    <div class="mb-6">
      <%= link_to "← All Event", events_path,
        class: "inline-block px-4 py-2 border border-[#95C24A] rounded-xl text-sm text-gray-700 hover:bg-green-50" %>

      <h1 class="text-2xl font-bold mt-4">Create Event</h1>
    </div>

    <%= form_with model: @event, class: "p-5 md:p-6 space-y-5" do |form| %>

     <div class="mb-4">
      <%= form.label :photo, "Photos (Optional)", class: "block mb-2 font-medium" %>

       <label class="flex items-center justify-center w-20 h-16 rounded-2xl border-gray-300 bg-white hover:border-[#95C24A] transition">
    
      <!-- icon -->
       <div class="text-[#95C24A] text-2xl"> 
       <%= image_tag "Add photo.png", width: 20, height: 20 %>
         </div>

        <!-- input จริง (ซ่อน) -->
        <%= form.file_field :photo,
        accept: "image/jpeg,image/png,image/heic",
        class: "hidden" %>
    </label>

  <% @event.errors.full_messages_for(:photo).each do |message| %>
    <p class="mt-1 text-sm text-red-600"><%= message %></p>
  <% end %>
</div>
    <div>
      <%= form.label :name, "Event Name" %><br>

      <%= form.text_field :name, 
        id: "event_name",
        required: true, 
        placeholder: "ลองแกล้งๆตั้งชื่อมาหน่อยจ้า", 
        class: "w-full p-3 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-[#95C24A]" %>
      <p id="name_error" class="text-red-500 text-sm mt-1"></p>
      </div>
      <div class="mb-4">
        <label class="block mb-2 font-medium">Activity Type</label>

        <div class="flex gap-3">

         <label class="cursor-pointer">
            <%= form.check_box :activity_type, { multiple: true, class: "hidden peer" }, "swimming", nil %>
            <div class="px-4 py-2 bg-white rounded-xl 
            flex items-center gap-2
            peer-checked:border-[#4AA2C2] 
            peer-checked:ring-1 peer-checked:ring-[#4AA2C2]">
             <%= image_tag "Swim.png", width: 20, height: 20 %>

            <span>Swimming</span>
            </div>
          </label>
          
          <label class="cursor-pointer">
            <%= form.check_box :activity_type, { multiple: true, class: "hidden peer" }, "running", nil %>
            <div class="px-4 py-2 bg-white rounded-xl
            flex items-center gap-2
            peer-checked:border-[#95C24A]
            peer-checked:ring-1 peer-checked:ring-[#95C24A]">
            <%= image_tag "Run.png", width: 20, height: 20 %>
            <span>Running</span>
            </div>
          </label>

          <label class="cursor-pointer">
            <%= form.check_box :activity_type, { multiple: true, class: "hidden peer" }, "cycling", nil %>
            <div class="px-4 py-2 bg-white rounded-xl
            flex items-center gap-2
            peer-checked:border-[#E76903]
            peer-checked:ring-1 peer-checked:ring-[#E76903]">
             <%= image_tag "Bike.png", width: 20, height: 20 %>
             <span>Cycling</span>
            </div>
          </label>
          
        </div>
      </div>
      <div class="mb-4">
      <label class="block mb-2 font-medium">Category</label>

      <div class="flex gap-3">

        <label class="cursor-pointer">
          <%= form.radio_button :category, "race", class: "hidden peer" %>
          <span class="px-4 py-2 rounded-lg bg-white
                      peer-checked:border-[#95C24A] peer-checked:ring-1 peer-checked:ring-[#95C24A]">
            Race
          </span>
        </label>

        <label class="cursor-pointer">
          <%= form.radio_button :category, "camp", class: "hidden peer" %>
          <span class="px-4 py-2 rounded-lg bg-white
                      peer-checked:border-[#95C24A] peer-checked:ring-1 peer-checked:ring-[#95C24A]">
            Camp
          </span>
        </label>

      </div>
    </div>
      <div>
        <%= form.label :description, "Description" %><br>
        <%= form.text_field :description,
        id: "description",
        required: true, 
        placeholder: "ทำกิจกรรมอะไรกันบ้าง, กินข้าวหรือดริ๊งๆ", 
        class: "w-full p-3 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-[#95C24A]" %>
        <p id="description_error" class="text-red-500 text-sm mt-1"></p>
      </div>
      <div>
        <%= form.label :location, "Location" %><br>
        <%= form.text_field :location_description, 
        id: "location",
        required: true,  
        placeholder: "ไหนลองบอกที่ๆจะไปมาหน่อยสิ๊", 
        class: "w-full p-3 mb-2 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-[#95C24A]" %><br>
        <p id="location_error" class="text-red-500 text-sm mt-1"></p>

        <%= form.text_field :location_link,
        id: "location_link",
        placeholder: "Link Google Map (Optional)", 
        class: "w-full p-3 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-[#95C24A]" %>
        <p id="location_link_error" class="text-red-500 text-sm mt-1"></p>

        </div>

      <div class="space-y-2">
        <label class="block text-sm font-medium">Date Range</label>

        <input
          type="text"
          id="date_range"
          name="date_range"
          class="w-full p-3 rounded-xl bg-white focus:outline-none focus:ring-2 focus:ring-[#95C24A]"
          placeholder="Select date range"
        >
        <%= form.hidden_field :start_date, required: true, id: "start_date" %>
        <%= form.hidden_field :end_date, required: true,id: "end_date" %>
      </div>

      <div>
      <%= form.submit "Create Event", id: "submit-btn", disabled: true, class: "w-full py-3 rounded-xl bg-gray-300 text-gray-500 font-medium cursor-not-allowed transition" %>
      </div>
    <% end %>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const form = document.querySelector("form");
  const submitBtn = document.getElementById("submit-btn");

  const fields = [
    { input: "event_name", error: "name_error", max: 200 },
    { input: "description", error: "description_error", max: 500 },
    { input: "location", error: "location_error", max: 200 }
  ];

  // validate length (reuse)
  fields.forEach(({ input, error, max }) => {
    const el = document.getElementById(input);
    const err = document.getElementById(error);

    el.addEventListener("input", () => {
      if (el.value.length > max) {
        err.textContent = "พิมพ์ยาวเกิ้นนน";
      } else {
        err.textContent = "";
      }
      toggleButton();
    });
  });

  // location link (URL check)
  const locationLinkInput = document.getElementById("location_link");
  const locationLinkError = document.getElementById("location_link_error");

  locationLinkInput.addEventListener("input", () => {
    const value = locationLinkInput.value;

    if (!value) {
      locationLinkError.textContent = "";
    } else {
      try {
        new URL(value);
        locationLinkError.textContent = "";
      } catch {
        locationLinkError.textContent = "ต้องเป็น URL นะ";
      }
    }
    toggleButton();
  });

  // activity check
  function isActivityTypeValid() {
    return document.querySelectorAll("input[name='event[activity_type][]']:checked").length > 0;
  }

  // date check
  function isDateValid() {
    const start = document.getElementById("start_date").value;
    const end = document.getElementById("end_date").value;
    return start && end && new Date(end) >= new Date(start);
  }

  // main toggle
  function toggleButton() {
    const isValid =
      form.checkValidity() &&
      isActivityTypeValid() &&
      isDateValid();

    submitBtn.disabled = !isValid;

    submitBtn.classList.toggle("bg-gray-300", !isValid);
    submitBtn.classList.toggle("text-gray-500", !isValid);
    submitBtn.classList.toggle("cursor-not-allowed", !isValid);

    submitBtn.classList.toggle("bg-[#95C24A]", isValid);
    submitBtn.classList.toggle("text-white", isValid);
    submitBtn.classList.toggle("hover:bg-green-600", isValid);
  }

  // bind form events
  form.addEventListener("input", toggleButton);
  form.addEventListener("change", toggleButton);

  // date range
  const dateRangeInput = document.getElementById("date_range");
  const startDateInput = document.getElementById("start_date");
  const endDateInput = document.getElementById("end_date");

  dateRangeInput.addEventListener("input", (e) => {
    const value = e.target.value;
    if (!value.includes("to")) return;

    const [start, end] = value.split(" to ");
    startDateInput.value = start;
    endDateInput.value = end;

    toggleButton();
  });

  toggleButton();
});
</script>