<h1 class="text-3xl font-semibold text-gray-900 mb-4">Events</h1>

<% if @events_by_category.any? %>
  <% @events_by_category.each do |category, events| %>
    <div class="mb-6">
      <h2 class="text-2xl font-semibold text-gray-700 mb-3">
            <%= (category.presence || "uncategorized").capitalize %>
      </h2>
      <% events.each do |event| %>
        <div class="mb-3 rounded-xl bg-white p-4 shadow-sm">
          <h3 class="text-xl font-semibold text-gray-800"><%= event.name %></h3>
        </div>
      <% end %>
    </div>
  <% end %>
<% else %>
  <p>ยังไม่มี event</p>
<% end %>
