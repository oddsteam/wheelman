<div class="min-h-screen bg-gray-50 py-4">
  <!-- Back Button -->
  <div class="max-w-md mx-auto px-4 mb-4">
    <%= link_to events_path, class: "inline-flex items-center px-4 py-2 border border-[#95C24A] rounded-xl text-sm font-medium bg-white shadow-md" do %>
      ← All Event
    <% end %>
  </div>

  <div class="max-w-md mx-auto px-4 mt-4 mb-4">

    <!-- Title -->
    <h1 class="text-2xl font-normal text-gray-800 mb-4">MY EVENT</h1>

    <!-- Event Cards -->
    <div class="flex flex-col gap-3">
      <% @events.each do |event| %>
        <div class="bg-white rounded-xl p-5 shadow-sm">
          
          <!-- Title -->
          <h2 class="text-[20px] font-normal text-gray-900 mb-1">
            <%= event.name.presence || "XXXXXXXXXXXX" %>
          </h2>

          <!-- Date -->
          <p class="text-gray-400 text-sm">Date</p>
          <p class="text-gray-800 font-medium mb-3">
            <%= event.start_date %> -
            <%= event.end_date %>
          </p>

          <!-- Actions -->
          <div class="flex items-center gap-3">
            <%= link_to "Detail", event_path(event),
            class: "flex-1 flex items-center text-center text-gray-800 justify-center bg-[#95C24A] py-2 rounded-xl font-medium w-full" %>

          <!-- Delete Icon -->
          <%= link_to event_path(event),
                method: :delete,
                data: { confirm: "Are you sure?" },
                class: "w-12 h-12 items-center justify-center flex rounded-xl" do %>
                <%= image_tag "Buttons-Delete.png", width: 50, height: 50 %>
            <% end %>

          </div>

        </div>
      <% end %>
    </div>
  </div>
</div>