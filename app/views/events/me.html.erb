<div class="min-h-screen bg-gray-50 py-2 ">
  <!-- Back Button -->
  <div class="max-w-xl mx-auto">
    <%= link_to events_path, class: "inline-flex items-center px-4 py-2 border border-green-500 text-green-600 rounded-lg" do %>
      ← All Event
    <% end %>
  </div>

  <div class="max-w-xl mx-auto">

    <!-- Title -->
    <h1 class="text-2xl font-semibold text-gray-800 mb-6">MY EVENT</h1>

    <!-- Event Cards -->
    <div class="space-y-5">
      <% @events.each do |event| %>
        <div class="bg-gray-100 rounded-2xl p-5 shadow-sm">
          
          <!-- Title -->
          <h2 class="text-lg font-medium text-gray-800 mb-3">
            <%= event.name.presence || "XXXXXXXXXXXX" %>
          </h2>

          <!-- Date -->
          <p class="text-gray-400 text-sm mb-1">Date</p>
          <p class="text-gray-700 font-medium mb-4">
            <%= event.start_date %> -
            <%= event.end_date %>
          </p>

          <!-- Actions -->
          <div class="flex items-center justify-between">
            <%= link_to "Detail", event_path(event),
                class: "w-full mr-3 text-center bg-green-500 text-white py-3 rounded-xl font-medium hover:bg-green-600 transition" %>

          </div>

        </div>
      <% end %>
    </div>
  </div>
</div>